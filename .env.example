# ───────────────────────────────────────────────────────────────────────────
# Loop by Zak Cricket — environment variables
# Copy to `.env.local` for local dev. NEVER commit real keys.
# Only VITE_* vars are exposed to the browser; everything else is server-side.
# ───────────────────────────────────────────────────────────────────────────

# ── Frontend (safe to expose) ───────────────────────────────────────────────
# Supabase project URL and anon (public) key. The anon key is safe in the
# client because Row Level Security enforces per-academy data isolation.
# For the key, use your project's "publishable" key (new format:
# sb_publishable_...) or the legacy anon JWT — supabase-js accepts either here.
# Never put the "secret" key (sb_secret_...) / service-role key in a VITE_ var.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx

# ── Supabase Edge Functions secrets (server-side ONLY) ───────────────────────
# Set these with: supabase secrets set KEY=value
# The Anthropic key is used ONLY inside the `generate-report` edge function and
# is never shipped to the browser.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
# Service-role key — used by edge functions for privileged writes. NEVER expose.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_URL=https://your-project.supabase.co

# Anthropic model used for AI report writing.
ANTHROPIC_MODEL=claude-opus-4-8

# ── WhatsApp (future upgrade path) ───────────────────────────────────────────
# Click-to-send needs no keys today. When upgrading to the official WhatsApp
# Business API, set these (server-side, used from an edge function).
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
